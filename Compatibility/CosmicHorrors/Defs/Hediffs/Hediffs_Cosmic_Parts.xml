<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<HediffDef ParentName="AddedXenomorphPart">
		<defName>XMT_TendrilMaw</defName>
		<label>feeding tendrils</label>
		<labelNoun>feeding tendrils</labelNoun>
		<description>numerous tendrils which writhe and consume food</description>
		<defaultInstallPart>StarbeastJaw</defaultInstallPart>
		<stages>
			<li>
				<capMods>
				  <li>
					<capacity>Eating</capacity>
					<offset>1</offset>
				  </li>
				</capMods>
			</li>
		</stages>
		<addedPartProps>
			<solid>true</solid>
			<betterThanNatural>true</betterThanNatural>
		</addedPartProps>
		<comps>
			<li Class="HediffCompProperties_VerbGiver">
				<tools>
				  <li>
					<label>tendril</label>
					<capacities>
					  <li>Stab</li>
					</capacities>
					<power>8</power>
					<cooldownTime>1</cooldownTime>
					<chanceFactor>0.75</chanceFactor>
					<surpriseAttack>
					  <extraMeleeDamages>
						<li>
						  <def>Bite</def>
						  <amount>15</amount>
						</li>
					  </extraMeleeDamages>
					</surpriseAttack>
					<soundMeleeHit>Pawn_Melee_BigBash_HitPawn</soundMeleeHit>
					<soundMeleeMiss>Pawn_Melee_BigBash_Miss</soundMeleeMiss>
				  </li>
				  <li>
					<label>inner teeth</label>
					<capacities>
					  <li>Stab</li>
					</capacities>
					<power>8</power>
					<cooldownTime>1</cooldownTime>
					<chanceFactor>0.75</chanceFactor>
					<surpriseAttack>
					  <extraMeleeDamages>
						<li>
						  <def>Bite</def>
						  <amount>15</amount>
						</li>
					  </extraMeleeDamages>
					</surpriseAttack>
					<soundMeleeHit>Pawn_Melee_BigBash_HitPawn</soundMeleeHit>
					<soundMeleeMiss>Pawn_Melee_BigBash_Miss</soundMeleeMiss>
				  </li>
				</tools>
			</li>
		</comps>
	</HediffDef>
	
	<HediffDef ParentName="XenomorphtypeBase">
		<defName>XMT_BackTentacles</defName>
		<label>back tentacles</label>
		<labelNoun>back tentacles</labelNoun>
		<isBad>false</isBad>
		<description>from the back emerge multiple fleshy tentacles capable of manipulation, movement and attack.</description>
		<defaultInstallPart>StarbeastTubes</defaultInstallPart>
		<stages>
			<li>
				<capMods>
				  <li>
					<capacity>Moving</capacity>
					<offset>1</offset>
				  </li>
				  <li>
					<capacity>Manipulation</capacity>
					<offset>1</offset>
				  </li>
				  <li>
					<capacity>Breathing</capacity>
					<offset>0.5</offset>
				  </li>
				</capMods>
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_VerbGiver">
				<tools>
				 <li>
					<label>tentacle</label>
					<capacities>
						<li>Scratch</li>
						<li>Stab</li>
					</capacities>
					<power>15</power>
					<cooldownTime>4</cooldownTime>
					<linkedBodyPartsGroup>StarbeastTailAttackTool</linkedBodyPartsGroup>
					<chanceFactor>0.12</chanceFactor>
					<surpriseAttack>
					  <extraMeleeDamages>
						<li>
						  <def>Stab</def>
						  <amount>15</amount>
						</li>
					  </extraMeleeDamages>
					</surpriseAttack>
					<soundMeleeHit>Pawn_Melee_BigBash_HitPawn</soundMeleeHit>
					<soundMeleeMiss>Pawn_Melee_BigBash_Miss</soundMeleeMiss>
				  </li>
				</tools>
			</li>
			<li>
				<compClass>Xenomorphtype.HediffComp_CarboSilicateMeat</compClass>
			</li>
		</comps>
	</HediffDef>

	<HediffDef ParentName="XenomorphtypeBase">
		<defName>XMT_Meat</defName>
		<label>hypertrophied musculature</label>
		<labelNoun>hypertrophied musculature</labelNoun>
		<initialSeverity>1</initialSeverity>
		<description>musclegroups across the body have strained the carapace leaving a vibrant red flesh exposed.</description>
		<stages>
			<li>
				<becomeVisible>true</becomeVisible>
				<minSeverity>1</minSeverity>
				<statOffsets>
					<MeleeDodgeChance>1</MeleeDodgeChance>
					<MeleeCooldownFactor>-0.25</MeleeCooldownFactor>
					<InjuryHealingFactor>1</InjuryHealingFactor>
				</statOffsets>
			</li>
		</stages>
		<addedPartProps>
			<solid>true</solid>
		</addedPartProps>
		<comps>
			
		</comps>
	</HediffDef>
	
</Defs>