<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef ParentName="BuildingBase">
		<defName>XMT_Petrolsump</defName>
		<thingClass>Xenomorphtype.Petrolsump</thingClass>
		<label>Oozing Fleshmass</label>
		<comps>
			<li>
				<compClass>Xenomorphtype.CompHiveGeneHolder</compClass>
			</li>
			<li Class="Xenomorphtype.CompPetrolsumpProperties">
				<sporeKindDef>XMT_Petrolspore</sporeKindDef>
			</li>
			<li Class="Xenomorphtype.CompAcidBloodProperties">
				<appliedHediff>AcidCorrosion</appliedHediff>
				<splashRange>1.5</splashRange>
				<cells>3</cells>
				<damage>10</damage>
			</li>
			<li Class="Xenomorphtype.CompHorrifyThingProperties">
				<thingHorrifiedByThis>Boomalope</thingHorrifiedByThis>
			</li>
		</comps>
		<modExtensions>
			<li Class="Xenomorphtype.XMT_HorrorPawnExtension">
				<tier>2</tier>
				<promotionTargets><li><thingDef>XMT_PetrolPool</thingDef></li></promotionTargets>
				<demotionTargets><li><pawnKind>XMT_Petrolspore</pawnKind></li></demotionTargets>
			</li>
		</modExtensions>
		<description>a strange amorpheous mass of quivering flesh, covered in sloshing, turgid sacks. It writhes at the ground wet and hungrily, it trembles and heaves in a terribly pained manner, it oozes rank secretions.</description>
		<graphicData>
			<texPath>Things/Building/PetrolSump</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shadowData>
				<volume>(0.3, 0.6, 0.3)</volume>
				<offset>(0,0,-0.1)</offset>
			</shadowData>
			<drawSize>1</drawSize>
		</graphicData>
		<filthLeaving>Filth_Fuel</filthLeaving>
		<drawerType>RealtimeOnly</drawerType>
		<minifiedDef></minifiedDef>
		<altitudeLayer>Building</altitudeLayer>
		<passability>PassThroughOnly</passability>
		<selectable>true</selectable>
		<fillPercent>0.20</fillPercent>
		<uiIconScale>0.6</uiIconScale>
		<uiIconOffset>(0, 0.1)</uiIconOffset>
		<leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
		<rotatable>false</rotatable>
		<tickerType>Normal</tickerType>
		<terrainAffordanceNeeded></terrainAffordanceNeeded> <!-- so they can be placed on anything?-->
		<statBases>
			<MaxHitPoints>42</MaxHitPoints>
			<Mass>60</Mass>
			<Flammability>0.0</Flammability>
			<MarketValue>42</MarketValue>
			<WorkToBuild>1000</WorkToBuild>
		</statBases>
		<specialDisplayRadius>4</specialDisplayRadius>
		<building>
			<deconstructible>false</deconstructible>
			<claimable>false</claimable>
			<repairable>false</repairable>
			<expandHomeArea>false</expandHomeArea>
			<ai_chillDestination>false</ai_chillDestination>
		</building>
		<!--<designationCategory>Xenomorphtype</designationCategory>-->
		<placeWorkers>
			<li>PlaceWorker_NeverAdjacentTrap</li>
		</placeWorkers>
	</ThingDef>
	
	<ThingDef ParentName="BuildingBase">
		<defName>XMT_PetrolPool</defName>
		<thingClass>Xenomorphtype.JellyWell</thingClass>
		<label>chemfuel fountain</label>
		<comps>
			<li>
				<compClass>Xenomorphtype.CompHiveGeneHolder</compClass>
			</li>
			<li Class="Xenomorphtype.CompJellyMakerProperties">
				<jellyIngredientFilter>
					<categories>
						<li>Leathers</li>
						<li>Foods</li>
						<li>Corpses</li>
						<li>PlantMatter</li>
						<li>Fabric</li>
						<li>Wools</li>
						<li MayRequire="DankPyon.Medieval.Overhaul">ResourcesRaw</li>
						<li MayRequire="DankPyon.Medieval.Overhaul">FoodRaw</li>
						<li MayRequire="DankPyon.Medieval.Overhaul">DankPyon_RawWood</li>
					</categories>
					<thingDefs>
						<li>WoodLog</li>
						<li>Starbeast_Resin</li>
						<li>Cloth</li>
						<li>DevilstrandCloth</li>
					</thingDefs>
					<disallowedCategories>
						<li>CorpsesMechanoid</li>
					</disallowedCategories>
					<disallowedThingDefs>
						<li>Chemfuel</li>
					</disallowedThingDefs>
				</jellyIngredientFilter>
				<processingWork>50</processingWork>
				<conversionRate>0.45</conversionRate>
				<jellyProduct>Chemfuel</jellyProduct>
			</li>
			<li Class="PipeSystem.CompProperties_Resource" MayRequire="VanillaExpanded.VChemfuelE">
				<pipeNet>VCHE_ChemfuelNet</pipeNet>
			</li>
			<li Class="Xenomorphtype.CompJellywellProperties"/>
			<li Class="Xenomorphtype.CompAcidBloodProperties">
				<appliedHediff>AcidCorrosion</appliedHediff>
			</li>
			<li Class="CompProperties_Explosive">
				<explosiveRadius>4.9</explosiveRadius>
				<explosiveDamageType>Flame</explosiveDamageType>
				<startWickHitPointsPercent>0.2</startWickHitPointsPercent>
				<preExplosionSpawnSingleThingDef>Filth_BlastMark</preExplosionSpawnSingleThingDef>
				<wickTicks>15</wickTicks>
				<startWickOnDamageTaken>
					<li>Bullet</li>
					<li>Flame</li>
					<li>ArrowHighVelocity</li>
					<li>Bomb</li>
				</startWickOnDamageTaken>
			</li>
		</comps>
		<modExtensions>
			<li Class="Xenomorphtype.XMT_HorrorPawnExtension">
				<tier>3</tier>
				<demotionTargets><li><thingDef>XMT_Petrolsump</thingDef></li></demotionTargets>
			</li>
		</modExtensions>
		<description>A strange fountain which draws in organic materials through its roots and converts it into high grade chemfuel. Did it just move?</description>
		<graphicData>
			<texPath>Things/Building/PetrolPool/PetrolPool</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawRotated>false</drawRotated>
			<drawSize>2.5</drawSize>
		</graphicData>
		<filthLeaving>Filth_Fuel</filthLeaving>
		<drawerType>RealtimeOnly</drawerType>
		<minifiedDef>MinifiedThing</minifiedDef>
		<altitudeLayer>Building</altitudeLayer>
		<passability>Impassable</passability>
		<selectable>true</selectable>
		<fillPercent>0.5</fillPercent>
		<uiIconScale>0.6</uiIconScale>
		<uiIconOffset>(0, 0.1)</uiIconOffset>
		<leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
		<defaultPlacingRot>South</defaultPlacingRot>
		<tickerType>Normal</tickerType>
		<statBases>
			<MaxHitPoints>800</MaxHitPoints>
			<Mass>300</Mass>
			<Flammability>4</Flammability>
			<MarketValue>42</MarketValue>
			<WorkToBuild>1000</WorkToBuild>
		</statBases>
		<specialDisplayRadius>1.5</specialDisplayRadius>
		<building>
			<repairable>false</repairable>
			<expandHomeArea>false</expandHomeArea>
			<ai_chillDestination>false</ai_chillDestination>
		</building>
		<costList>
			<Starbeast_Flesh_Meat>120</Starbeast_Flesh_Meat>
			<Chemfuel>80</Chemfuel>
		</costList>
		<killedLeavings>
			<Starbeast_Flesh_Meat>120</Starbeast_Flesh_Meat>
			<Chemfuel>80</Chemfuel>
		</killedLeavings>
		<thingCategories>
			<li>BuildingsSecurity</li>
		</thingCategories>
		<placeWorkers>
			<li>PlaceWorker_NeverAdjacentTrap</li>
		</placeWorkers>
	</ThingDef>
	
	<ThingDef ParentName="BuildingBase">
		<defName>XMT_SlumberingBeast</defName>
		<thingClass>Xenomorphtype.Slumberer</thingClass>
		<label>Slumbering Mass</label>
		<comps>
			<li>
				<compClass>Xenomorphtype.CompHiveGeneHolder</compClass>
			</li>
			<li Class="Xenomorphtype.CompSlumbererProperties">
				<slumbererKindDef>XMT_Slumberbeast</slumbererKindDef>
			</li>
			<li Class="Xenomorphtype.CompAcidBloodProperties">
				<appliedHediff>AcidCorrosion</appliedHediff>
				<splashRange>3</splashRange>
				<cells>3</cells>
				<damage>20</damage>
			</li>
		</comps>
		<modExtensions>
			<li Class="Xenomorphtype.XMT_HorrorPawnExtension">
				<tier>2</tier>
				<promotionTargets><li><pawnKind>XMT_Jagerbar</pawnKind></li></promotionTargets>
			</li>
		</modExtensions>
		<description>a heaving mass of jellid flesh riddled in veins with a skeleton floating within, it trembles and heaves in a slow, ponderous manner.</description>
		<graphicData>
			<texPath>Things/Building/SlumberBeast</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shadowData>
				<volume>(0.3, 0.6, 0.3)</volume>
				<offset>(0,0,-0.1)</offset>
			</shadowData>
			<drawSize>1</drawSize>
		</graphicData>
		<filthLeaving>Filth_Fuel</filthLeaving>
		<drawerType>RealtimeOnly</drawerType>
		<minifiedDef></minifiedDef>
		<altitudeLayer>Building</altitudeLayer>
		<passability>PassThroughOnly</passability>
		<selectable>true</selectable>
		<fillPercent>0.20</fillPercent>
		<uiIconScale>0.6</uiIconScale>
		<uiIconOffset>(0, 0.1)</uiIconOffset>
		<leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
		<rotatable>false</rotatable>
		<tickerType>Normal</tickerType>
		<terrainAffordanceNeeded></terrainAffordanceNeeded> <!-- so they can be placed on anything?-->
		<statBases>
			<MaxHitPoints>42</MaxHitPoints>
			<Mass>60</Mass>
			<Flammability>0.0</Flammability>
			<MarketValue>42</MarketValue>
			<WorkToBuild>1000</WorkToBuild>
		</statBases>
		<specialDisplayRadius>4</specialDisplayRadius>
		<building>
			<deconstructible>false</deconstructible>
			<claimable>false</claimable>
			<repairable>false</repairable>
			<expandHomeArea>false</expandHomeArea>
			<ai_chillDestination>false</ai_chillDestination>
		</building>
		<!--<designationCategory>Xenomorphtype</designationCategory>-->
		<placeWorkers>
			<li>PlaceWorker_NeverAdjacentTrap</li>
		</placeWorkers>
	</ThingDef>
</Defs>
