	<GeneDef>
		<defName>XMT_Flipper_Locomotion</defName>
		<geneClass>Xenomorphtype.XenomorphGene</geneClass>
		<label>flipper locomotion</label>
		<labelShortAdj>flippered</labelShortAdj>
		<iconPath>UI/Icons/Genes/Gene_WebbedPhalanges</iconPath>
		<description>Carriers of this gene move through water with little resistance, but their limbs are awkward on dry land.</description>
		<displayCategory>Movement</displayCategory>
		<displayOrderInCategory>501</displayOrderInCategory>
		<selectionWeight>0</selectionWeight>
		<biostatCpx>1</biostatCpx>
		<biostatMet>1</biostatMet>
		<waterCellCost MayRequire="Ludeon.RimWorld.Odyssey">1</waterCellCost>
