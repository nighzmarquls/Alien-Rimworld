<?xml version="1.0" encoding="utf-8" ?>
<Patch>
	
	<Operation Class="PatchOperationAdd">
		<success>Always</success>
		<xpath>/Defs/ThingDef[@Name="BasePawn"]/comps</xpath>
		<value>
			<li>
				<compClass>Xenomorphtype.CompPawnInfo</compClass>
			</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<success>Always</success>
		<xpath>/Defs/ThingDef[modExtensions/li[@Class="Xenomorphtype.XMT_HorrorPawnExtension"] and not(@ParentName="XMT_Base_Pod") and not(comps/li/compClass="Xenomorphtype.CompHiveGeneHolder")]/comps</xpath>
		<value>
			<li>
				<compClass>Xenomorphtype.CompHiveGeneHolder</compClass>
			</li>
		</value>
	</Operation>
</Patch>
